{
  "version": 2,
  "buildCommand": "npm run build:all",
  "outputDirectory": "Frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api"
    },
    {
      "src": "/health",
      "dest": "/api"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.js)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.css)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.svg)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.png)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.jpg)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.jpeg)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.gif)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.woff2?)$",
      "dest": "/$1"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
