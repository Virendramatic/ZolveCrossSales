# Database - Use Supabase connection string from env var
DATABASE_URL=${DATABASE_URL}

# Server
PORT=3000
NODE_ENV=production
VERCEL=1

# JWT - Use env vars for security
JWT_SECRET=${JWT_SECRET}
JWT_REFRESH_SECRET=${JWT_REFRESH_SECRET}
JWT_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# Logging
LOG_LEVEL=info
